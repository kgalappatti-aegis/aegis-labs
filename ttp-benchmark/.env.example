# Copy to .env and fill in, or export these in your shell.

# Claude (Anthropic) — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Kimi K3 (Moonshot AI) — OpenAI-compatible endpoint
# International: https://api.moonshot.ai/v1   |  China: https://api.moonshot.cn/v1
MOONSHOT_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1

# Qwen (Alibaba DashScope) — OpenAI-compatible endpoint
# International: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
